    :: ((sevNeed == patientNeedInit) || (trndSevNeed == outsideHomeCare)) -&gt; sevNeed = outsideHomeCare
    :: ((sevNeed != patientNeedInit) &amp;&amp; (trndSevNeed == homeCare)) -&gt; sevNeed = discharge
    fi
    trndSevNeed = sevNeed</bpmn:documentation>
